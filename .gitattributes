# Set default behavior to automatically normalize line endings to LF
* text=auto eol=lf

# Python source files
*.py text eol=lf
*.pyx text eol=lf
*.pyi text eol=lf

# Configuration files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Documentation
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf

# Data files
*.csv text eol=lf
*.tsv text eol=lf
*.jsonl text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows batch files (exception - need CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf

# Exclude files from export
.gitattributes export-ignore
.gitignore export-ignore

# Binary files
*.pyc binary
*.pyo binary
*.pyd binary
*.so binary
*.dll binary
*.exe binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
