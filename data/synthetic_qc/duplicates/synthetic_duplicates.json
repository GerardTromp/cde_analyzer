      {
        "designation": "Total mass of lead present per unit dry weight of soil as determined by acid digestion and instrumental analysis",
        "sources": null,
        "tags": [
          "Soil Composition Analysis"
        ]
      }
    ],
    "definitions": [
      {
        "definition": "Total lead concentration is measured by digesting a dried and ground soil sample in concentrated acid, filtering the digest, and analyzing the filtrate by inductively coupled plasma mass spectrometry or atomic absorption spectroscopy. The concentration is reported in milligrams per kilogram. Lead is a persistent heavy metal contaminant whose accumulation in soil poses risks to human health through direct contact, dust inhalation, and uptake into food crops.",
        "sources": null,
        "tags": [
          "Soil Composition Analysis"
        ]
      }
    ]
