digraph CDE_Core_Schema {
    graph [
        rankdir=TB
        fontname="Helvetica"
        fontsize=11
        label="CDE Core Data Model"
        labelloc=t
        pad=0.4
        nodesep=0.6
        ranksep=1.0
        bgcolor=white
    ];
    node [
        shape=none
        fontname="Helvetica"
        fontsize=10
    ];
    edge [
        fontname="Helvetica"
        fontsize=9
        color="#555555"
        arrowsize=0.8
    ];

ValueDomain [label=<
