    <TR><TD ALIGN="LEFT" PORT="ids"><B><FONT COLOR="#1e8e3e">ids</FONT></B></TD><TD ALIGN="LEFT"><FONT COLOR="#1e8e3e">List[Identifier]?</FONT></TD></TR>
    <TR><TD ALIGN="LEFT">name</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">str?</FONT></TD></TR>
    <TR><TD ALIGN="LEFT" PORT="permissibleValues"><B><FONT COLOR="#1e8e3e">permissibleValues</FONT></B></TD><TD ALIGN="LEFT"><FONT COLOR="#1e8e3e">List[PermissibleValue]?</FONT></TD></TR>
    <TR><TD ALIGN="LEFT">uom</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">str?</FONT></TD></TR>
