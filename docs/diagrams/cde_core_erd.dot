    // Relationships
    ValueDomain:identifiers -> Identifier [arrowhead=crowodot  label="  1..*  "];
    ValueDomain:ids -> Identifier [arrowhead=crowodot  label="  1..*  "];
    ValueDomain:permissibleValues -> PermissibleValue [arrowhead=crowodot  label="  1..*  "];
    CDEItem:designations -> Designation [arrowhead=crowodot  label="  1..*  "];
    CDEItem:definitions -> Definition [arrowhead=crowodot  label="  1..*  "];
    CDEItem:valueDomain -> ValueDomain [arrowhead=vee style=dashed label="  1  "];
    CDEItem:ids -> Identifier [arrowhead=crowodot  label="  1..*  "];
}